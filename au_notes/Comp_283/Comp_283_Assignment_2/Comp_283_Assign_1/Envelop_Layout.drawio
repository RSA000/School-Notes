          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ekr3Sa7Gujgn25rdjJ_G-157" value="The quality of food can varied and be divided between&amp;nbsp;&lt;span style=&quot;background-color: initial;&quot;&gt;the&amp;nbsp;&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;levels differently. Providing better food to different sections&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;will provide&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;benefits,&lt;/span&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&amp;nbsp;such as faster research time, maintenance, or waste management.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1020" y="458" width="440" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ekr3Sa7Gujgn25rdjJ_G-169" value="The spa raises the morale of all first level crew, but at the expense of angering the lower levels." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
