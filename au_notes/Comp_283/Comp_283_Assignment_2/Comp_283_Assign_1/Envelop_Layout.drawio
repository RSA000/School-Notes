        </mxCell>
        <mxCell id="ekr3Sa7Gujgn25rdjJ_G-155" value="The court is where individuals or groups faiths are decided by the ruling party" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
