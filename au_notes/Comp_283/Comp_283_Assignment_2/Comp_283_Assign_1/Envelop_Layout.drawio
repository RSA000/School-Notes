        </mxCell>
        <mxCell id="ekr3Sa7Gujgn25rdjJ_G-147" value="The Scientists quarter are roomier with more luxuries.&amp;nbsp;&lt;div&gt;The Council is where edicts are passed.&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
