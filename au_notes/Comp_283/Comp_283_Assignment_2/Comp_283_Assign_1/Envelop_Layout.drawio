        </mxCell>
        <mxCell id="ekr3Sa7Gujgn25rdjJ_G-151" value="The Navigation Centre is used to view the&lt;div&gt;&amp;nbsp;various maps and set a course.&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
