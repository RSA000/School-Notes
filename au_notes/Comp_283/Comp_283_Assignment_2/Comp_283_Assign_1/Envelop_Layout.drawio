        <mxCell id="ekr3Sa7Gujgn25rdjJ_G-145" value="Norberts secret facilities can be used to&amp;nbsp;&lt;div&gt;develop powerful tools for survival.&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
