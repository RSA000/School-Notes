          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ekr3Sa7Gujgn25rdjJ_G-153" value="The agricultural, hull and facilities, and&amp;nbsp;&lt;div&gt;biological research are used to develop tech trees.&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
