        <mxCell id="ekr3Sa7Gujgn25rdjJ_G-176" value="Crew can be assigned to security detail, but require equipment and extra rations. Employing to much security result in the upper level being taken over." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
