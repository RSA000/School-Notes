        <mxCell id="XZpaEk4sSjdcldhfkn0V-10" value="Hull anodes protect the outer hull by acting as a sacrificial metal. Anodes decay over time and need to be replaced. If the Envelop runs out of anodes, the outer hull will begin to erode and cause major damage." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#333333;fontFamily=Times New Roman;" parent="1" vertex="1">
          <mxGeometry x="1040" y="205" width="130" height="160" as="geometry" />
