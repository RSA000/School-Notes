          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="XZpaEk4sSjdcldhfkn0V-69" value="Oxygen recycling will allow the Envelop to submerge for longer periods of time." style="whiteSpace=wrap;html=1;rounded=0;fillColor=#333333;fontFamily=Times New Roman;" parent="1" vertex="1">
          <mxGeometry x="1050" y="495" width="120" height="60" as="geometry" />
