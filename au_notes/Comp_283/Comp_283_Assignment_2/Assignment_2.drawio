          <mxGeometry x="1215" y="250" width="80" height="80" as="geometry" />
        </mxCell>
        <mxCell id="XZpaEk4sSjdcldhfkn0V-14" value="Repairing the outer hull is an arduous task. It requires surfacing and sending out a crew to patch any major corrosion. The transport vessels are also required for repairs below the Envelop. The Envelop can only be repaired a handful of times before damage cannot be repaired.&lt;div&gt;Crew can either volunteer or be coerced to join the scuba crew, which can result in deaths or direct exposure to contaminated water.&lt;br&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#333333;fontFamily=Times New Roman;" parent="1" vertex="1">
          <mxGeometry x="1515" y="175" width="190" height="230" as="geometry" />
        </mxCell>
