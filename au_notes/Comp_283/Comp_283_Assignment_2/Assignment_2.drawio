        <mxCell id="XZpaEk4sSjdcldhfkn0V-67" value="Filtration Systems and Oxygen Recycling" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#66B2FF;fontFamily=Helvetica;" parent="1" vertex="1">
          <mxGeometry x="910" y="440" width="120" height="50" as="geometry" />
        </mxCell>
