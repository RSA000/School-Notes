          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="XZpaEk4sSjdcldhfkn0V-71" value="Filtration systems will purify outside air" style="whiteSpace=wrap;html=1;rounded=0;fillColor=#333333;fontFamily=Times New Roman;" parent="1" vertex="1">
          <mxGeometry x="1050" y="580" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="XZpaEk4sSjdcldhfkn0V-73" value="Air filtration systems need replacement filters. Alternatives, such as rags or other fabrics, can be used if no filters are available, but will contaminate submarine." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#333333;fontFamily=Times New Roman;" parent="1" vertex="1">
