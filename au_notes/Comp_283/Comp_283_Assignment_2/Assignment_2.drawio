          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="XZpaEk4sSjdcldhfkn0V-53" value="Anodes will last longer." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#333333;fontFamily=Times New Roman;" parent="1" vertex="1">
          <mxGeometry x="270" y="630" width="120" height="75" as="geometry" />
        </mxCell>
        <mxCell id="XZpaEk4sSjdcldhfkn0V-95" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="XZpaEk4sSjdcldhfkn0V-55" target="XZpaEk4sSjdcldhfkn0V-56" edge="1">
          <mxGeometry relative="1" as="geometry" />
