        <mxCell id="XZpaEk4sSjdcldhfkn0V-55" value="Consequence" style="rhombus;whiteSpace=wrap;html=1;fillColor=#990000;" parent="1" vertex="1">
          <mxGeometry x="477.5" y="762.5" width="65" height="70" as="geometry" />
        </mxCell>
        <mxCell id="XZpaEk4sSjdcldhfkn0V-56" value="Morale is lowered. Portions of the translated texts reach the crew. This can increase Norbert&#39;s secret following.&amp;nbsp;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#333333;fontFamily=Times New Roman;" parent="1" vertex="1">
          <mxGeometry x="270" y="766.25" width="120" height="122.5" as="geometry" />
        </mxCell>
        <mxCell id="XZpaEk4sSjdcldhfkn0V-57" value="Norbert had detailed knowledge of the various protocols used to end the world scattered throughout his rantings. It appears things will get worse before they get better, with an estimated ten years before the continuous reaction stops. The detailed description of the early stages of this reaction has allowed our fabricator to produce anodes with greater efficiency&amp;nbsp;&amp;nbsp;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#333333;fontFamily=Times New Roman;" parent="1" vertex="1">
          <mxGeometry y="652.5" width="195" height="230" as="geometry" />
        </mxCell>
        <mxCell id="XZpaEk4sSjdcldhfkn0V-66" value="Commanding Officers" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#009999;" parent="1" vertex="1">
          <mxGeometry x="-1760" y="215" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="XZpaEk4sSjdcldhfkn0V-70" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fillColor=#333333;fontFamily=Times New Roman;" parent="1" source="XZpaEk4sSjdcldhfkn0V-67" target="XZpaEk4sSjdcldhfkn0V-69" edge="1">
          <mxGeometry relative="1" as="geometry" />
