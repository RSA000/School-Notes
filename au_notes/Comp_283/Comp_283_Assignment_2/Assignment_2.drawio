        <mxCell id="VAwB5ETcgbmX8kY6HmwC-9" value="&lt;h3&gt;Lower Level&lt;/h3&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#121212;" vertex="1" parent="1">
